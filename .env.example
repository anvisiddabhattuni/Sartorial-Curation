# Copy to backend/.env and fill in. Every provider is swappable here.

# Provider selection
EMBEDDING_PROVIDER=fashionclip   # fashionclip | stub
VIBE_PROVIDER=gemini             # gemini | stub
PRODUCT_PROVIDER=mock            # mock | serpapi
VECTOR_STORE=pgvector            # pgvector | memory

# Keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
SERPAPI_API_KEY=

# Database (pgvector). Falls back to in-memory store if unreachable.
DATABASE_URL=postgresql://localhost:5432/muse

# Frontend origin(s) for CORS — comma-separated, e.g. to allow both local dev
# and a deployed frontend at once:
# FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# Public URL of this API once deployed (used for locally-served mock product
# images and CORS reference) — defaults to localhost for local dev.
API_BASE_URL=http://localhost:8000

# Per-IP rate limits (protects against one client hammering the API).
UPLOAD_RATE_LIMIT=15         # POST /boards per window
ANALYZE_RATE_LIMIT=8         # analyze + refine per window (these cost $)
RATE_LIMIT_WINDOW_SECONDS=3600

# Daily ceilings on Gemini/SerpAPI calls, shared across all visitors — the
# safety net for a public link getting more traffic than expected. <=0
# disables a cap. Tune to your actual plan: SerpAPI free/hobby tiers are
# often monthly-limited, so a low daily number that spreads the monthly
# quota across the month is safer than a high one.
GEMINI_DAILY_LIMIT=300
SERPAPI_DAILY_LIMIT=30

# Frontend API URL (copy to frontend/.env.local as NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
