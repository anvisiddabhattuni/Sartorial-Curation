# Copy to backend/.env and fill in. Every provider is swappable here.

# Provider selection
EMBEDDING_PROVIDER=fashionclip   # fashionclip | stub
VIBE_PROVIDER=gemini             # gemini | stub
PRODUCT_PROVIDER=mock            # mock | serpapi
VECTOR_STORE=pgvector            # pgvector | memory

# Keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
SERPAPI_API_KEY=

# Database (pgvector). Falls back to in-memory store if unreachable.
DATABASE_URL=postgresql://localhost:5432/muse

# Frontend origin(s) for CORS — comma-separated, e.g. to allow both local dev
# and a deployed frontend at once:
# FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# Public URL of this API once deployed (used for locally-served mock product
# images and CORS reference) — defaults to localhost for local dev.
API_BASE_URL=http://localhost:8000

# Frontend API URL (copy to frontend/.env.local as NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
